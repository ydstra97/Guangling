-- 5. [MODULE] FLY ENGINE (SEAMLESS)
-- ==========================================
Guangling:RegisterModule("Fly", {
    Speed = 50, Level = 1, Held = {W=false,A=false,S=false,D=false,UP=false,DOWN=false},
    LastStopTime = 0, IdlePos = nil,
    
    CleanupEngine = function(self)
        if self.BV then self.BV:Destroy(); self.BV = nil end
        if self.BG then self.BG:Destroy(); self.BG = nil end
    end,
    
    UpdatePhysicsMover = function(self, rp, hum)
        self:CleanupEngine()
        if Guangling.Config.FlyMode == "Modern" then
            hum.PlatformStand = true; rp.Anchored = false; hum.AutoRotate = false
            self.BV = Instance.new("BodyForce"); self.BV.Name = "MAG_"..tostring(math.random(10,99)); self.BV.Parent = rp
        else
            hum.PlatformStand = false; rp.Anchored = false; hum.AutoRotate = false
            self.BV = Instance.new("BodyVelocity"); self.BV.Name = "MoverVel"; self.BV.Velocity = Vector3.zero; self.BV.MaxForce = Vector3.new(1e5,1e5,1e5); self.BV.Parent = rp
            self.BG = Instance.new("BodyGyro"); self.BG.Name = "MoverGyro"; self.BG.MaxTorque = Vector3.new(1e5,1e5,1e5); self.BG.D = 50; self.BG.Parent = rp
        end
    end,
    
    OnEnable = function(self)
        local char = LocalPlayer.Character
        local rp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not rp or not hum then return end
        
        self:UpdatePhysicsMover(rp, hum)
        
        self.Connections.Loop = RunService.RenderStepped:Connect(function(dt)
            local currentRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            local currentHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if not currentRP or not currentHum then Guangling:ToggleModule("Fly", false); return end
            
            local cam = workspace.CurrentCamera
            local spd = self.Speed * self.Level
            local dir = Vector3.zero
            if self.Held.W then dir += cam.CFrame.LookVector end; if self.Held.S then dir -= cam.CFrame.LookVector end
            if self.Held.D then dir += cam.CFrame.RightVector end; if self.Held.A then dir -= cam.CFrame.RightVector end
            if self.Held.UP then dir += Vector3.new(0,1,0) end; if self.Held.DOWN then dir -= Vector3.new(0,1,0) end
            
            local targetVel = dir.Magnitude > 0 and dir.Unit * spd or Vector3.zero
            
            if Guangling.Config.FlyMode == "Modern" then
                currentHum.PlatformStand = true; currentRP.Anchored = false
                if self.BV and self.BV.Parent then self.BV.Force = Vector3.new(0, workspace.Gravity * currentRP.AssemblyMass, 0) end
                
                if targetVel.Magnitude > 0 then
                    self.IdlePos = nil
                    currentRP.AssemblyLinearVelocity = targetVel
                    currentRP.CFrame = currentRP.CFrame:Lerp(CFrame.new(currentRP.Position + (targetVel*dt), currentRP.Position + (targetVel*dt) + cam.CFrame.LookVector), 0.4)
                else
                    if not self.IdlePos then self.IdlePos = currentRP.Position end
                    currentRP.AssemblyLinearVelocity = Vector3.zero; currentRP.AssemblyAngularVelocity = Vector3.zero
                    currentRP.CFrame = currentRP.CFrame:Lerp(CFrame.new(self.IdlePos, self.IdlePos + cam.CFrame.LookVector), 0.4)
                end
            else
                if self.BV and self.BV.Parent then self.BV.Velocity = targetVel + Vector3.new(0, (not self.Held.UP and not self.Held.DOWN) and 0.5 or 0, 0) end
                if self.BG and self.BG.Parent then self.BG.CFrame = cam.CFrame end
            end
        end)
    end,
    OnDisable = function(self)
        self.LastStopTime = tick()
        for _, c in pairs(self.Connections) do c:Disconnect() end; self.Connections = {}
        for k in pairs(self.Held) do self.Held[k] = false end
        self:CleanupEngine()
        
        local char = LocalPlayer.Character
        local rp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if rp then rp.Anchored = false; rp.AssemblyLinearVelocity = Vector3.zero end
        if hum then hum.PlatformStand = false; hum.AutoRotate = true; hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
    end
})

