-- 6. [MODULE] ESP CULLING ENGINE
-- ==========================================
Guangling:RegisterModule("ESP", {
    MaxDist = 500, RayParams = RaycastParams.new(),
    
    RemoveESP = function(self, player)
        local data = Guangling.Cache.Players[player]
        if not data then return end
        for _, c in ipairs(data.Conns) do c:Disconnect() end
        if data.HL then data.HL:Destroy() end
        if data.Bill then data.Bill:Destroy() end
        Guangling.Cache.Players[player] = nil
    end,
    
    AttachESP = function(self, player)
        if player == LocalPlayer or not player.Character then return end
        self:RemoveESP(player)
        
        local data = {HL = nil, Bill = nil, Txt = nil, Conns = {}, isAttaching = true, lastRay = 0, lastTxt = 0, isVis = true}
        Guangling.Cache.Players[player] = data
        
        local function setup(char)
            if not self.Enabled or char.Parent ~= workspace then data.isAttaching = false; return end
            local hrp = char:WaitForChild("HumanoidRootPart", 3)
            if not hrp then data.isAttaching = false; return end
            
            if data.HL then data.HL:Destroy() end
            if data.Bill then data.Bill:Destroy() end
            
            local hl = Instance.new("Highlight")
            hl.FillColor = Guangling.Config.ESP_Color; hl.OutlineColor = Guangling.Config.ESP_Color; hl.FillTransparency = 0.8; hl.OutlineTransparency = 0; hl.Parent = char
            
            local bill = Instance.new("BillboardGui")
            bill.Size = UDim2.new(0,150,0,40); bill.StudsOffset = Vector3.new(0,3,0); bill.AlwaysOnTop = true; bill.Adornee = hrp; bill.Parent = CoreGui
            
            local txt = Instance.new("TextLabel")
            txt.Size = UDim2.new(1,0,1,0); txt.BackgroundTransparency = 1; txt.TextColor3 = Guangling.Config.ESP_Color; txt.TextStrokeTransparency = 0.2; txt.Font = Enum.Font.GothamBold; txt.TextSize = 11; txt.RichText = true; txt.Parent = bill
            
            data.HL = hl; data.Bill = bill; data.Txt = txt; data.isAttaching = false
        end
        
        task.defer(function() setup(player.Character) end)
        table.insert(data.Conns, player.CharacterAdded:Connect(setup))
    end,
    
    OnEnable = function(self)
        self.RayParams.FilterType = Enum.RaycastFilterType.Exclude
        for _, p in ipairs(Players:GetPlayers()) do self:AttachESP(p) end
        
        self.Connections.Add = Players.PlayerAdded:Connect(function(p) self:AttachESP(p) end)
        self.Connections.Rem = Players.PlayerRemoving:Connect(function(p) self:RemoveESP(p) end)
        
        local valTimer, lastUpd = 0, 0
        self.Connections.Loop = RunService.Heartbeat:Connect(function(dt)
            local now = tick()
            if now - lastUpd < 0.12 then return end
            lastUpd = now
            
            if now - valTimer > 2 then
                valTimer = now
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= LocalPlayer and p.Character then
                        local d = Guangling.Cache.Players[p]
                        if (not d or not d.HL or not d.HL.Parent) and (not d or not d.isAttaching) then self:AttachESP(p) end
                    end
                end
            end
            
            local myRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if not myRP then return end
            self.RayParams.FilterDescendantsInstances = {LocalPlayer.Character}
            
            for p, d in pairs(Guangling.Cache.Players) do
                if not p.Character or d.isAttaching then continue end
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                if hrp and d.HL then
                    local dist = (hrp.Position - myRP.Position).Magnitude
                    if dist <= self.MaxDist then
                        local _, onScreen = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
                        if onScreen then
                            if dist <= 200 then
                                if now - d.lastRay > 0.25 then
                                    local filter = {LocalPlayer.Character, hrp.Parent}
                                    self.RayParams.FilterDescendantsInstances = filter
                                    d.isVis = workspace:Raycast(myRP.Position, hrp.Position - myRP.Position, self.RayParams) == nil
                                    d.lastRay = now
                                end
                            else d.isVis = false end
                            
                            local head = p.Character:FindFirstChild("Head")
                            if head and head.Transparency > 0.5 then
                                d.HL.Enabled = false
                            else
                                d.HL.DepthMode = (not d.isVis and 4) or (dist < 50 and 2) or 1
                                d.HL.Enabled = true
                            end
                            
                            if d.Bill and d.Txt then
                                d.Bill.Enabled = true
                                if now - d.lastTxt > 0.5 then
                                    d.lastTxt = now
                                    local eHum = p.Character:FindFirstChildOfClass("Humanoid")
                                    local hp = eHum and math.floor(eHum.Health) or 0
                                    local hpCol = hp > 50 and "<font color='rgb(50,255,50)'>" or "<font color='rgb(255,50,50)'>"
                                    d.Txt.Text = string.format("%s\n<font color='rgb(200,200,200)'>[%d m]</font> | %sHP: %d</font>", p.Name, math.floor(dist), hpCol, hp)
                                end
                            end
                        else
                            d.HL.Enabled = false; if d.Bill then d.Bill.Enabled = false end
                        end
                    else
                        d.HL.Enabled = false; if d.Bill then d.Bill.Enabled = false end
                    end
                end
            end
        end)
    end,
    OnDisable = function(self)
        for _, c in pairs(self.Connections) do c:Disconnect() end; self.Connections = {}
        for p in pairs(Guangling.Cache.Players) do self:RemoveESP(p) end
    end
})

