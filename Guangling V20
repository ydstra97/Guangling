-- Singleton Framework Object
local Guangling = {
    Version = "V20.0.0 Modular Framework",
    Modules = {},
    Connections = {},
    Cache = {
        Players = {},
        Parts = setmetatable({}, {__mode = "v"}) -- Weak table (Anti Memory Leak)
    },
