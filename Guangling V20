Guangling:RegisterModule("PlayerState", {
    OnEnable = function(self)
        self.Enabled = true
        self.Connections.Loop = RunService.Heartbeat:Connect(function()
            local hum = getHumanoid()
            if hum and hum.Health > 0 and hum.WalkSpeed ~= Guangling.Config.WalkSpeed then
                hum.WalkSpeed = Guangling.Config.WalkSpeed
            end
        end)
    end,
    OnDisable = function(self)
        self.Enabled = false
        for _, c in pairs(self.Connections) do c:Disconnect() end; self.Connections = {}
        local hum = getHumanoid()
        if hum then hum.WalkSpeed = 16 end
    end,
    ToggleJump = function(self, state)
