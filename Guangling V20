            self.Connections.Jump = UIS.JumpRequest:Connect(function()
                local hum = getHumanoid()
                if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
            end)
        else
            if self.Connections.Jump then self.Connections.Jump:Disconnect(); self.Connections.Jump = nil end
        end
    end
})

