-- 4. [MODULE] NOCLIP & ANTI-VOID
-- ==========================================
Guangling:RegisterModule("Noclip", {
    OnEnable = function(self)
        local util = Guangling.Modules["CoreUtilities"]
        local char = LocalPlayer.Character
        for _, part in pairs(Guangling.Cache.Parts) do
            if part and part.Parent and char and part:IsDescendantOf(char) and part:IsA("BasePart") then
                if util.psWorks then pcall(function() part.CollisionGroup = "GuanglingPhantom" end)
                else part.CanCollide = false end
            end
        end
        
        self.Connections.Loop = RunService.Stepped:Connect(function()
            local flyMod = Guangling.Modules["Fly"]
            if flyMod and flyMod.Enabled then return end
            -- Guard Anti-Void Cooldown (0.6s)
            if flyMod and tick() - flyMod.LastStopTime < 0.6 then return end 
            
            local char = LocalPlayer.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum or hum.Health <= 0 then return end
            
            -- Velocity Gate: Aktif hanya jika jatuh ekstrem
            if hrp.AssemblyLinearVelocity.Y < -40 then
                local rp = RaycastParams.new(); rp.FilterType = Enum.RaycastFilterType.Exclude; rp.FilterDescendantsInstances = {char}
                local mode = Guangling.Config.AntiVoidMode
                local rayDir = (mode == "Light") and Vector3.new(0,-4,0) or (mode == "Smart") and (hrp.CFrame.LookVector * 1.5 + Vector3.new(0,-6,0)) or (hrp.CFrame.LookVector * 3 + Vector3.new(0,-12,0))
                
                local hit = workspace:Raycast(hrp.Position, rayDir, rp)
                if hit then
                    if hrp.AssemblyLinearVelocity.Y < 0 then hrp.AssemblyLinearVelocity = Vector3.new(hrp.AssemblyLinearVelocity.X, 0, hrp.AssemblyLinearVelocity.Z) end
                    local targetY = hit.Position.Y + (hum.HipHeight > 0 and hum.HipHeight or 2) + (hrp.Size.Y / 2)
                    if hrp.Position.Y < targetY - 0.1 then
                        hrp.CFrame = hrp.CFrame:Lerp(hrp.CFrame + Vector3.new(0, targetY - hrp.Position.Y, 0), 0.3)
                    end
                end
            end
        end)
    end,
    OnDisable = function(self)
        for _, c in ipairs(self.Connections) do c:Disconnect() end; self.Connections = {}
        local util = Guangling.Modules["CoreUtilities"]
        local char = LocalPlayer.Character
        for _, part in pairs(Guangling.Cache.Parts) do
            if part and part.Parent and char and part:IsDescendantOf(char) and part:IsA("BasePart") then
                if util.psWorks then pcall(function() part.CollisionGroup = "Default" end) end
                part.CanCollide = true
            end
        end
    end
})

