        WalkSpeed = 16,
        ESP_Color = Color3.fromRGB(255, 215, 0)
    }
}
_G.GuanglingV20 = Guangling

-- Core Functions
function Guangling:Conn(c)
    table.insert(self.Connections, c)
    return c
end

function Guangling:RegisterModule(name, moduleTable)
    moduleTable.Name = name
    moduleTable.Enabled = false
    moduleTable.Connections = {}
    self.Modules[name] = moduleTable
    if moduleTable.OnInit then moduleTable:OnInit() end
end

function Guangling:ToggleModule(name, state)
    local mod = self.Modules[name]
    if not mod then return end
    if state ~= nil then mod.Enabled = state else mod.Enabled = not mod.Enabled end
    
    if mod.Enabled and mod.OnEnable then 
        mod:OnEnable() 
    elseif not mod.Enabled and mod.OnDisable then 
        mod:OnDisable() 
    end
end

function Guangling.Cleanup()
    for _, mod in pairs(Guangling.Modules) do
        if mod.Enabled and mod.OnDisable then pcall(function() mod:OnDisable() end) end
        for _, c in ipairs(mod.Connections) do pcall(function() c:Disconnect() end) end
    end
    for _, c in ipairs(Guangling.Connections) do pcall(function() c:Disconnect() end) end
    local gui = CoreGui:FindFirstChild("GuanglingGUI_V20")
    if gui then gui:Destroy() end
    pcall(function() PS:UnregisterCollisionGroup("GuanglingPhantom") end)
end

-- ==========================================
-- 2. [MODULE] CACHE & UTILITIES
-- ==========================================
Guangling:RegisterModule("CoreUtilities", {
    OnInit = function(self)
        self.psWorks = pcall(function()
            PS:RegisterCollisionGroup("GuanglingPhantom")
            PS:CollisionGroupSetCollidable("GuanglingPhantom", "Default", false)
        end)
        
        self.RefreshCache = function(char)
            if self.DescendantConn then self.DescendantConn:Disconnect() end
            Guangling.Cache.Parts = setmetatable({}, {__mode = "v"})
            if not char then return end
            
            for _, v in ipairs(char:GetDescendants()) do
                if v:IsA("BasePart") then table.insert(Guangling.Cache.Parts, v) end
            end
            
            self.DescendantConn = char.DescendantAdded:Connect(function(desc)
                if desc:IsA("BasePart") then 
                    table.insert(Guangling.Cache.Parts, desc) 
                    local ncMod = Guangling.Modules["Noclip"]
                    if ncMod and ncMod.Enabled then
                        if self.psWorks then pcall(function() desc.CollisionGroup = "GuanglingPhantom" end)
                        else desc.CanCollide = false end
                    end
                end
            end)
        end
        
        Guangling:Conn(LocalPlayer.CharacterAdded:Connect(function(char)
            self.RefreshCache(char)
            local wsMod = Guangling.Modules["PlayerState"]
            if wsMod and wsMod.Enabled then
                task.delay(0.1, function()
                    local hum = char:WaitForChild("Humanoid", 5)
                    if hum then hum.WalkSpeed = Guangling.Config.WalkSpeed end
                end)
            end
            local ncMod = Guangling.Modules["Noclip"]
            if ncMod and ncMod.Enabled then task.delay(0.1, function() ncMod:OnEnable() end) end
        end))
        
        if LocalPlayer.Character then self.RefreshCache(LocalPlayer.Character) end
    end
})

